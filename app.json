{
  "expo": {
    "name": "Captional",
    "slug": "captional",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/app_assets/captional_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.blazingautomations.captional",
      "versionCode": 1,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Captional needs access to your photos to add captions."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Captional saves your captioned photos to your gallery.",
          "savePhotosPermission": "Captional saves your captioned photos to your gallery."
        }
      ]
    ]
  }
}
